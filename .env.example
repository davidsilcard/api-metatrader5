APP_ENV=development
APP_LOG_LEVEL=INFO
APP_HOST=127.0.0.1
APP_PORT=8000
APP_LOG_FILE=logs/api-metatrader5.log
APP_LOG_MAX_BYTES=10485760
APP_LOG_BACKUP_COUNT=5

# HMAC server-to-server
MT5_GATEWAY_KEY_ID=edge-1
MT5_GATEWAY_SHARED_SECRET=change-this-secret
MT5_GATEWAY_SCOPES=quotes:read,symbols:read,orders:preview,metrics:read

# Opcao avancada para multiplas chaves. Se definida, tem precedencia.
HMAC_SHARED_KEYS=
HMAC_KEY_SCOPES=
HMAC_ALLOWED_CLOCK_SKEW_SECONDS=30
HMAC_NONCE_TTL_SECONDS=300

# Alias opcionais para diferenca entre ticker publico e ticker efetivo consultado
# Formato: PETR4=PETR4F,VALE3=VALE3F
MT5_SYMBOL_ALIASES=

# Backend de mercado: BTG Trader Desk local
BTG_TRADER_DESK_HOST=127.0.0.1
BTG_TRADER_DESK_PORT=9099
BTG_TRADER_DESK_TOKEN=
BTG_TRADER_DESK_TIMEOUT_SECONDS=2.0

# Opcional: catalogo local para alimentar /internal/v1/symbols/search
# Aceita .csv com colunas symbol,description,path,digits,...
# ou arquivo texto simples com um ticker por linha.
BTG_TRADER_DESK_SYMBOLS_FILE=
BTG_TRADER_DESK_CURRENCY=BRL
BTG_TRADER_DESK_DEFAULT_DIGITS=2
QUOTE_CACHE_TTL_MS=250
