APP_ENV=development
APP_LOG_LEVEL=INFO
APP_HOST=127.0.0.1
APP_PORT=8000
APP_LOG_FILE=logs/api-metatrader5.log
APP_LOG_MAX_BYTES=10485760
APP_LOG_BACKUP_COUNT=5

# Opcao simples para um unico consumidor server-to-server
MT5_GATEWAY_KEY_ID=edge-1
MT5_GATEWAY_SHARED_SECRET=change-this-secret
MT5_GATEWAY_SCOPES=quotes:read,symbols:read,orders:preview

# Opcao avancada para multiplas chaves. Se definida, tem precedencia.
# Formato: key_id=secret,key_id_2=secret_2
HMAC_SHARED_KEYS=
# Formato: key_id=scope1|scope2,key_id_2=*
HMAC_KEY_SCOPES=
HMAC_ALLOWED_CLOCK_SKEW_SECONDS=30
HMAC_NONCE_TTL_SECONDS=300

# Alias opcionais para diferenca entre ticker publico e simbolo real do broker
# Formato: BBDCG189=BBDCG189F,VALEK92=VALEK92F
MT5_SYMBOL_ALIASES=

# Opcional: caminho do terminal MT5
MT5_TERMINAL_PATH=

# Opcional: credenciais explicitas. Se omitir, usa a sessao logada do terminal.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

MT5_DEFAULT_DEVIATION=20
MT5_MAGIC_NUMBER=500001
MT5_ORDER_COMMENT_PREFIX=api-metatrader5
MT5_ENABLE_ORDER_SEND=0
MT5_RECONNECT_MAX_ATTEMPTS=3
MT5_RECONNECT_BACKOFF_SECONDS=1.0
MT5_CONNECTION_PROBE_INTERVAL_SECONDS=5

